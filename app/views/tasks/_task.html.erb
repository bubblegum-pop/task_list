<div id="<%= dom_id task %>">
  <p>
    <strong>Task name:</strong>
    <%= task.task_name %>
  </p>

  <p>
    <strong>Urgent:</strong>
    <%= task.urgent %>
  </p>

  <p>
    <strong>Important:</strong>
    <%= task.important %>
  </p>

  <p>
    <strong>Complete:</strong>
    <%= task.complete %>
  </p>

</div>
